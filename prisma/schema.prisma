// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id              String    @id @default(cuid())
  name            String
  description     String?
  manufactureDate DateTime
  expiryDate      DateTime
  skinType        String?   // e.g., "da dầu", "da khô", "da nhạy cảm"
  suitableFor     String?   // e.g., "nam/nữ", "trẻ em", "người lớn"
  pros            String[]  // ưu điểm
  cons            String[]  // nhược điểm
  ingredientAnalysis String? // phân tích thành phần chi tiết
  tags            String[]  // tags để tìm kiếm
  status          ProductStatus @default(PUBLISHED)
  publishedAt     DateTime?
  purchaseLinks   Json?     // [{ platform: 'Shopee', url: '...' }, { platform: 'Tiki', url: '...' }]
  imageUrl        String?   // deprecated - sử dụng ProductImage thay thế
  companyName     String
  companyAddress  String?
  verified        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  qrCodes  QrCode[]
  images   ProductImage[]
  versions ProductVersion[]

  @@index([companyName])
  @@index([status])
  @@index([publishedAt])
}

model ProductImage {
  id         String   @id @default(cuid())
  productId  String
  url        String   // Supabase Storage URL
  altText    String?
  sortOrder  Int      // để sắp xếp thứ tự ảnh
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([sortOrder])
}

model ProductVersion {
  id           String   @id @default(cuid())
  productId    String
  productSnapshot Json   // full snapshot của product
  imageSnapshot Json?    // snapshot của product images (array stored as JSON)
  changedBy    String   // adminUserId
  changeReason String?  // lý do chỉnh sửa
  createdAt    DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([createdAt])
}

model AdminUser {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String   // bcrypt hash
  email     String?  @unique
  role      UserRole @default(ADMIN)
  isActive  Boolean  @default(true)
  lastLogin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ScanLog {
  id         String    @id @default(cuid())
  qrCode     String
  ipAddress  String?
  userAgent  String?
  scannedAt  DateTime  @default(now())

  @@index([qrCode])
  @@index([scannedAt])
  @@map("scan_logs")
}

model QrCode {
  id            String    @id @default(cuid())
  code          String    @unique                // 6 ký tự hash (vd "AB12CD")
  url           String                          // URL đầy đủ, vd "https://urcheck.vercel.app/?q=AB12CD"
  productId     String
  scanCount     Int       @default(0)
  lastScannedAt DateTime?
  isActive      Boolean   @default(true)        // Có thể tắt QR cũ khi cần
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([productId])
  @@index([scanCount])
  @@map("qr_codes")
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum UserRole {
  ADMIN
  CUSTOMER
}
