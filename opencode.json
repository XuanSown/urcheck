{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-supabase"],
  "mcp": {
    "supabase": {
      "type": "local",
      "command": ["npx", "-y", "@supabase/mcp-server-supabase"],
      "enabled": true,
      "env": {
        "SUPABASE_ACCESS_TOKEN": "{env:SUPABASE_ACCESS_TOKEN}"
      }
    }
  }
}
